{
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": "main"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": { "name": "conventionalcommits" },
      "infile": "CHANGELOG.md",
      "header": "# Changelog\n\nGenerated automatically from conventional commits."
    }
  },
  "hooks": {
    "before:init": ["npm run typecheck", "npm run test", "npm run build"]
  }
}
